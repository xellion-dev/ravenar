generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model users {
  id         String    @id @db.VarChar(255)
  username   String?   @db.VarChar(255)
  password   String?   @db.VarChar(255)
  registered DateTime? @db.DateTime(0)
  last_login DateTime? @db.DateTime(0)
}
